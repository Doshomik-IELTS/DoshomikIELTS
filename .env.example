# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ieltsplusplus
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/ieltsplusplus

# Redis / BullMQ
REDIS_URL=redis://localhost:6379

# LLM / transcription providers
LLM_PROVIDER=  # Options: openai, anthropic, gemini
LLM_API_KEY=
LLM_MODEL_WRITING=  # e.g. gpt-4o, claude-sonnet-4-20250514, gemini-2.0-flash
LLM_MODEL_SPEAKING=  # e.g. gpt-4o-mini, claude-haiku-3-20240307, gemini-2.0-flash
LLM_MODEL_CONTENT_VALIDATION=
TRANSCRIPTION_PROVIDER=
TRANSCRIPTION_API_KEY=
TRANSCRIPTION_MODEL=

# Storage limits
MAX_SPEAKING_AUDIO_MB=25
MAX_SPEAKING_AUDIO_SECONDS=300
SIGNED_URL_TTL_SECONDS=900

# Strapi CMS (optional until the CMS service is running)
STRAPI_BASE_URL=http://localhost:1337
STRAPI_ADMIN_URL=http://localhost:1337/admin
STRAPI_API_TOKEN=

# Sentry (optional - error tracking, not required for beta)
# To enable: Install @sentry/nextjs and configure after creating a Sentry project
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# PostHog (optional - learner/product analytics)
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# NEXT_PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com

# Dev Auth (development only — never set in production)
DEV_LEARNER_EMAIL=demo@ieltspp.local
DEV_LEARNER_PASSWORD=
DEV_LEARNER_NAME=Demo Learner
DEV_LEARNER_TARGET_BAND=6.5
DEV_LEARNER_EXAM_DATE=2026-12-31
DEV_LEARNER_NATIVE_LANGUAGE=Bangla
DEV_LEARNER_STUDY_GOAL=Reach IELTS 6.5+ with strong foundations
DEV_ADMIN_EMAIL=admin@ieltspp.local
DEV_ADMIN_PASSWORD=
DEV_ADMIN_NAME=Demo Admin
DEV_ADMIN_TARGET_BAND=7.0
DEV_ADMIN_EXAM_DATE=2026-06-30
DEV_ADMIN_NATIVE_LANGUAGE=English
DEV_ADMIN_STUDY_GOAL=Admin access for testing
