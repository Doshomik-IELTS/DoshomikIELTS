{
  "collectionName": "components_tests_answer_keys",
  "info": {
    "displayName": "Answer Key",
    "description": "Correct answer and scoring metadata."
  },
  "attributes": {
    "canonicalAnswer": {
      "type": "string",
      "required": true
    },
    "acceptedAnswers": {
      "type": "json"
    },
    "acceptedAnswersText": {
      "type": "text"
    },
    "scoringRuleType": {
      "type": "enumeration",
      "enum": [
        "exact",
        "case_insensitive",
        "contains",
        "regex",
        "manual_rubric"
      ],
      "default": "case_insensitive"
    },
    "points": {
      "type": "integer",
      "default": 1
    },
    "scoringRule": {
      "type": "json"
    },
    "explanation": {
      "type": "richtext"
    }
  }
}
