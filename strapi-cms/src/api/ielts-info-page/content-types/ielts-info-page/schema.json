{
  "kind": "collectionType",
  "collectionName": "ielts_info_pages",
  "info": {
    "singularName": "ielts-info-page",
    "pluralName": "ielts-info-pages",
    "displayName": "IELTS Info Page",
    "description": "Fees, centers, preparation guides, referral terms, and other IELTS information pages."
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "fees",
        "centers",
        "preparation",
        "referral",
        "other"
      ],
      "required": true
    },
    "body": {
      "type": "richtext",
      "required": true
    },
    "orderIndex": {
      "type": "integer",
      "default": 0
    },
    "media": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files"
      ]
    }
  }
}
