{
  "kind": "collectionType",
  "collectionName": "resources",
  "info": {
    "singularName": "resource",
    "pluralName": "resources",
    "displayName": "Resource",
    "description": "IELTS++ lessons, vocabulary, grammar, spelling, and strategy resources."
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "basic_english",
        "words",
        "synonyms",
        "grammar",
        "reading_strategy",
        "listening_strategy",
        "writing_strategy",
        "speaking_strategy"
      ],
      "required": true
    },
    "difficulty": {
      "type": "enumeration",
      "enum": [
        "basic",
        "intermediate",
        "advanced"
      ],
      "default": "basic",
      "required": true
    },
    "body": {
      "type": "richtext",
      "required": true
    },
    "examples": {
      "type": "component",
      "repeatable": true,
      "component": "content.example"
    },
    "tags": {
      "type": "json"
    },
    "orderIndex": {
      "type": "integer",
      "default": 0
    },
    "prerequisites": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::resource.resource"
    },
    "media": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "audios",
        "videos"
      ]
    }
  }
}
