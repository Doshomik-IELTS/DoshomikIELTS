{
  "kind": "collectionType",
  "collectionName": "resources",
  "info": {
    "singularName": "resource",
    "pluralName": "resources",
    "displayName": "Resource",
    "description": "DOshomik IELTS lessons, vocabulary, grammar, spelling, and strategy resources."
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "basic_english",
        "words",
        "synonyms",
        "antonyms",
        "collocations",
        "idioms_phrases",
        "phrasal_verbs",
        "word_forms",
        "pronunciation",
        "grammar",
        "spelling",
        "punctuation",
        "sentence_structure",
        "common_mistakes",
        "common_topics",
        "common_topics_qa",
        "reading_strategy",
        "reading_question_types",
        "listening_strategy",
        "listening_question_types",
        "writing_strategy",
        "writing_task_1_academic",
        "writing_task_1_general",
        "writing_task_2",
        "speaking_strategy",
        "speaking_part_1",
        "speaking_part_2",
        "speaking_part_3",
        "question_ideas",
        "sample_questions",
        "sample_answers",
        "scenarios",
        "band_descriptors",
        "exam_strategy",
        "study_plan",
        "academic_ielts",
        "general_training_ielts",
        "video_course"
      ],
      "required": true
    },
    "difficulty": {
      "type": "enumeration",
      "enum": [
        "basic",
        "intermediate",
        "advanced"
      ],
      "default": "basic",
      "required": true
    },
    "body": {
      "type": "richtext",
      "required": true
    },
    "summary": {
      "type": "text"
    },
    "banglaTitle": {
      "type": "string"
    },
    "banglaSummary": {
      "type": "text"
    },
    "banglaTranslation": {
      "type": "richtext"
    },
    "module": {
      "type": "enumeration",
      "enum": [
        "general",
        "listening",
        "reading",
        "writing",
        "speaking"
      ],
      "default": "general"
    },
    "accessTier": {
      "type": "enumeration",
      "enum": [
        "free",
        "paid",
        "internal"
      ],
      "default": "free",
      "required": true
    },
    "estimatedStudyMinutes": {
      "type": "integer"
    },
    "examples": {
      "type": "component",
      "repeatable": true,
      "component": "content.example"
    },
    "vocabularyItems": {
      "type": "component",
      "repeatable": true,
      "component": "content.vocabulary-item"
    },
    "tags": {
      "type": "json"
    },
    "tagItems": {
      "type": "component",
      "repeatable": true,
      "component": "content.tag"
    },
    "orderIndex": {
      "type": "integer",
      "default": 0
    },
    "prerequisites": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::resource.resource"
    },
    "media": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "audios",
        "videos"
      ]
    },
    "sourceAttribution": {
      "type": "text"
    },
    "editorNotes": {
      "type": "text"
    },
    "reviewChecklist": {
      "type": "json"
    }
  }
}
